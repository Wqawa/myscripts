-- 平台参数
local PLATFORM_SIZE = Vector3.new(20, 1, 20)
local PLATFORM_COLOR = Color3.fromRGB(255, 0, 0)
local PLATFORM_TRANSPARENCY = 0.9

-- 平台状态
local isPlatformActive = false
local platformPart = nil
local fixedY = 0
local heartBeatConnection = nil

